<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; GLOBALS, BREEDS, AND OWNERSHIP VARIABLES
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

globals [
  victims-found        ;; counter for how many victims have been detected
  total-victims        ;; total victims placed at setup
  search-complete?     ;; true when all flood patches are searched
  coverage-percent     ;; % of flood area searched (used by plot)
]

breed [leader-drones leader-drone]
breed [follower-drones follower-drone]
breed [victims victim]

patches-own [
  flood?       ;; true = this patch is part of the flood zone
  obstacle?    ;; true = building / blocked terrain
  searched?    ;; true = a drone has passed over this patch
  sector-id    ;; 1–4, which quadrant sector this patch belongs to
]

leader-drones-own [
  energy       ;; battery level (for future battery feature)
]

follower-drones-own [
  my-sector    ;; sector number assigned at spawn (1–4)
  energy
]

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SETUP — called by the Setup button
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup
  clear-all
  setup-environment
  assign-sectors
  setup-victims
  setup-drones
  set victims-found 0
  set total-victims num-victims
  set search-complete? false
  set coverage-percent 0
  reset-ticks
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; ENVIRONMENT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup-environment
  ;; Step 1 — reset all patches to "deep water" (black/dark blue)
  ask patches [
    set flood?    false
    set obstacle? false
    set searched? false
    set pcolor    black
  ]

  ;; Step 2 — define the main flood zone as a large rectangle
  ;; Adjust these bounds to make the zone bigger or smaller
  ask patches with [
    pxcor >= (min-pxcor + 3) and
    pxcor <= (max-pxcor - 3) and
    pycor >= (min-pycor + 3) and
    pycor <= (max-pycor - 3)
  ] [
    set flood? true
    set pcolor cyan + 1   ;; light cyan = shallow flood water
  ]

  ;; Step 3 — carve out obstacles (buildings, raised ground)
  ;; Uses clustered placement so buildings feel realistic
  setup-obstacles

  ;; Step 4 — draw a visible border around the flood zone
  ask patches with [
    not flood? and
    any? neighbors with [flood?]
  ] [
    set pcolor gray + 1   ;; border ring
  ]
end

to setup-obstacles
  ;; Place num-obstacles "seed" patches, then grow each into a small cluster
  ;; This creates building-block shapes rather than random scatter
  let seeds n-of num-obstacles patches with [flood?]

  ask seeds [
    set obstacle? true
    set flood?    false
    set pcolor    gray - 1

    ;; Grow cluster — each seed expands to up to 3 neighbours
    ask up-to-n-of 3 neighbors with [flood?] [
      set obstacle? true
      set flood?    false
      set pcolor    gray - 1
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; SECTOR ASSIGNMENT (divides map into 4 zones)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to assign-sectors
  ;; Divide flood zone into 4 quadrants
  ;; Each follower drone will be assigned one sector to patrol
  ask patches with [flood?] [
    (ifelse
      pxcor >= 0 and pycor >= 0 [ set sector-id 1 ]   ;; top-right
      pxcor <  0 and pycor >= 0 [ set sector-id 2 ]   ;; top-left
      pxcor <  0 and pycor <  0 [ set sector-id 3 ]   ;; bottom-left
                                 [ set sector-id 4 ]   ;; bottom-right
    )
    ;; Tint each sector a slightly different shade so you can see the division
    if sector-id = 1 [ set pcolor cyan ]
    if sector-id = 2 [ set pcolor cyan + 1 ]
    if sector-id = 3 [ set pcolor cyan + 2 ]
    if sector-id = 4 [ set pcolor cyan + 3 ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; VICTIM PLACEMENT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup-victims
  create-victims num-victims [
    ;; Place only on flood patches that aren't obstacles
    let target one-of patches with [flood? and not obstacle?]
    if target != nobody [ move-to target ]
    set color   red
    set shape   "person"
    set size    1.2
    set hidden? false
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; DRONE PLACEMENT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to setup-drones
  ;; Leader drone spawns at map centre
  create-leader-drones 1 [
    setxy 0 0
    set color   yellow
    set shape   "airplane"
    set size    2
    set heading 0
    set energy  100
  ]

  ;; Follower drones: one per sector, spawned inside their sector
  let sector-num 1
  create-follower-drones num-drones [
    set my-sector sector-num
    set sector-num (sector-num mod 4) + 1

    let spawn-patch one-of patches with [
      flood? and not obstacle? and sector-id = [my-sector] of myself
    ]
    if spawn-patch != nobody [ move-to spawn-patch ]

    set color   white
    set shape   "airplane"
    set size    1.5
    set heading random 360
    set energy  100
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; MAIN GO PROCEDURE
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to go
  if search-complete? [ stop ]

  ask leader-drones   [ lead ]
  ask follower-drones [ follow-and-search ]
  detect-victims
  mark-searched-patches
  update-coverage
  check-completion

  tick
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; LEADER DRONE BEHAVIOUR
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to lead
  ;; Leader oversees the whole map — it patrols in a wide sweep
  ;; and acts as a coordination anchor for followers

  smart-avoid          ;; check for obstacles ahead
  avoid-other-drones   ;; keep distance from other drones
  wiggle               ;; slight random turn to avoid loops
  fd drone-speed
  drain-battery
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; FOLLOWER DRONE BEHAVIOUR
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to follow-and-search
  smart-avoid
  avoid-other-drones
  stay-in-sector       ;; pull back toward assigned sector
  prefer-unsearched    ;; steer toward patches not yet covered
  wiggle
  fd drone-speed
  drain-battery
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; MOVEMENT PRIMITIVES
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to smart-avoid
  ;; Look ahead in a cone — if obstacle detected, turn away
  let danger patches in-cone 3 60 with [obstacle?]
  if any? danger [
    ;; Turn away from the closest obstacle
    let closest min-one-of danger [distance myself]
    face closest
    rt 150 + random 60   ;; sharp turn to clear the building
  ]

  ;; Also check the very next patch
  if [obstacle?] of patch-ahead 1 [
    rt 90 + random 90
  ]

  ;; Don't leave the flood zone
  if not [flood?] of patch-ahead 1 [
    rt 120 + random 60
  ]
  
end

to avoid-other-drones
  ;; Separation rule (from Boids) — steer away from nearby drones
  let nearby (turtle-set leader-drones follower-drones) in-radius separation-radius
  let nearby-others other nearby

  if any? nearby-others [
    let closest min-one-of nearby-others [distance myself]
    face closest
    rt 180   ;; face directly away
  ]
end

to stay-in-sector
  ;; If drone has drifted outside its sector, steer back
  if [sector-id] of patch-here != my-sector [
    let home-patch one-of patches with [
      flood? and not obstacle? and sector-id = [my-sector] of myself
    ]
    if home-patch != nobody [
      face home-patch
    ]
  ]
end

to prefer-unsearched
  ;; Look for nearby unsearched flood patches and turn toward them
  ;; This improves coverage efficiency significantly
  let target one-of patches in-radius 5 with [
    flood? and not obstacle? and not searched?
  ]
  if target != nobody [
    face target
  ]
end

to wiggle
  ;; Small random heading change to prevent drones getting stuck in loops
  rt random 20 - 10
end

to drain-battery
  set energy energy - battery-drain
  ;; Return to base to recharge when battery is low
  if energy <= 0 [
    setxy 0 0
    set energy 100
    output-print (word "Drone " who " returned to base to recharge.")
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; VICTIM DETECTION
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to detect-victims
  ask (turtle-set leader-drones follower-drones) [
    ;; Check detection radius around each drone
    let found victims in-radius detection-radius

    ask found [
      if color = red [   ;; only report undiscovered victims
        set color green  ;; green = found and reported
        set victims-found victims-found + 1
        output-print (word
          "Victim #" who
          " found at (" round xcor ", " round ycor ")"
          " by Drone " [who] of myself
        )
      ]
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; PATCH TRACKING
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to mark-searched-patches
  ask (turtle-set leader-drones follower-drones) [
    ;; Mark the patch the drone is currently on
    ask patch-here [
      if flood? and not obstacle? [
        set searched? true
        set pcolor blue + 2
      ]
    ]
    ;; Also mark nearby patches within sensor range
    ask patches in-radius sensor-radius with [flood? and not obstacle?] [
      set searched? true
      set pcolor blue + 2
    ]
  ]
end

to update-coverage
  let flood-count count patches with [flood? and not obstacle?]
  if flood-count > 0 [
    set coverage-percent
      (count patches with [searched?]) / flood-count * 100
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; COMPLETION CHECK
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to check-completion
  if count patches with [flood? and not obstacle? and not searched?] = 0 [
    set search-complete? true
    output-print "==============================="
    output-print "SEARCH COMPLETE"
    output-print (word "Victims found: " victims-found " / " total-victims)
    output-print (word "Time taken: " ticks " ticks")
    output-print "==============================="
  ]
end

to report-status
  output-print "==============================="
  output-print (word "Ticks elapsed : " ticks)
  output-print (word "Coverage      : " precision coverage-percent 1 "%")
  output-print (word "Victims found : " victims-found " / " total-victims)
  output-print (word "Drones active : " (count follower-drones + count leader-drones))
  output-print "==============================="
end]]></code>
  <widgets>
    <view x="368" wrappingAllowedX="true" y="10" frameRate="30.0" minPycor="-16" height="664" showTickCounter="true" patchSize="20.0" fontSize="10" wrappingAllowedY="true" width="664" tickCounterLabel="ticks" maxPycor="16" updateMode="0" maxPxcor="16" minPxcor="-16"></view>
    <button x="120" y="15" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55" display="Go">go</button>
    <button x="190" y="15" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="90" display="Report Status">report-status</button>
