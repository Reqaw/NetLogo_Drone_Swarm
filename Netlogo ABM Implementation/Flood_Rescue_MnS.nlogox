      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="coverage" color="-13345367" legend="true">
        <setup></setup>
        <update>plot coverage-percent</update>
      </pen>
    </plot>
    <monitor x="1360" precision="17" y="135" height="60" fontSize="11" width="100" display="Ticks elapsed">ticks</monitor>
    <monitor x="1465" precision="17" y="135" height="60" fontSize="11" width="110" display="Area searched %">(count patches with [searched?]) / (count patches with [flood?]) * 100</monitor>
    <plot x="1675" autoPlotX="true" yMax="20.0" autoPlotY="true" yAxis="Drones" y="205" xMin="0.0" height="295" legend="true" xMax="500.0" yMin="0.0" width="310" xAxis="Ticks" display="Drone Sector Discipline">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="in-sector" color="-10899396" legend="true">
        <setup></setup>
        <update>plot count follower-drones with [
                [sector-id] of patch-here = my-sector
              ]
</update>
      </pen>
